# =========================================================================
# store-monolit — przykładowa konfiguracja środowiska
# Skopiuj do .env i uzupełnij. Walidowane przez src/lib/env.ts (fail-fast).
# =========================================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Baza danych (PostgreSQL) ---
DATABASE_URL="postgresql://store:store@localhost:5432/store?schema=public"

# --- Auth.js (NextAuth v5) ---
# wygeneruj: openssl rand -base64 32
AUTH_SECRET="zmien-mnie-na-losowy-sekret"
AUTH_TRUST_HOST=true
# OAuth (opcjonalnie):
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# --- Wybór providerów (opcjonalny; pusty = auto wg dostępnych kluczy) ---
PAYMENT_PROVIDER=
SHIPPING_PROVIDER=

# --- Płatności: Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Wysyłka: Furgonetka (OAuth2 password grant) ---
FURGONETKA_CLIENT_ID=
FURGONETKA_CLIENT_SECRET=
FURGONETKA_USERNAME=
FURGONETKA_PASSWORD=
FURGONETKA_SANDBOX=true
FURGONETKA_COD_IBAN=
FURGONETKA_WEBHOOK_SECRET=
# Adres nadawcy (pickup/sender)
FURGONETKA_SENDER_NAME=
FURGONETKA_SENDER_STREET=
FURGONETKA_SENDER_POSTCODE=
FURGONETKA_SENDER_CITY=
FURGONETKA_SENDER_EMAIL=
FURGONETKA_SENDER_PHONE=
# Klucz Mapy Furgonetki (widget wyboru punktu w checkoucie). Publiczny — ograniczony
# domenowo w panelu Furgonetki (whitelist domen, np. localhost + produkcyjna).
# Pusty = brak mapy, klient wpisuje kod punktu ręcznie.
NEXT_PUBLIC_FURGONETKA_MAP_KEY=

# --- Storage (S3-compatible: MinIO / AWS / R2) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=store-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/store-media
S3_FORCE_PATH_STYLE=true

# --- Email (Resend lub SMTP) ---
EMAIL_PROVIDER=console
EMAIL_FROM="Sklep <noreply@example.com>"
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- KSeF (Krajowy System e-Faktur) ---
# Wyłączone = provider e-fakturowania `none` (no-op). Włącz, by wysyłać faktury do KSeF.
# Auth docelowy: certyfikat KSeF (od 1.01.2027 jedyna metoda). Token tylko do testów (wygasa 31.12.2026).
KSEF_ENABLED=false
KSEF_ENV=test            # test | demo | prod (środowiska są odseparowane)
KSEF_NIP=
# Ścieżka A — certyfikat (XAdES), metoda docelowa (od 1.01.2027):
KSEF_CERT_PATH=                       # certyfikat PEM (ustawienie włącza auth XAdES)
KSEF_KEY_PATH=                        # klucz prywatny PEM
KSEF_CERT_PASSWORD=                   # hasło klucza (jeśli zaszyfrowany)
KSEF_CERT_SUBJECT_TYPE=certificateFingerprint  # albo certificateSubject (cert kwalifikowany z NIP)
# Ścieżka B — token (prostsza, do testów; wygasa 31.12.2026):
KSEF_TOKEN=

# --- Feature flags ---
FEATURE_MARKETING=true
FEATURE_CMS=true
FEATURE_MULTIREGION=false
FEATURE_DIGITAL=false
FEATURE_INVOICES=true
REQUIRE_AUTH_CHECKOUT=false

# --- Domyślne ustawienia sklepu ---
DEFAULT_CURRENCY=PLN
DEFAULT_LOCALE=pl
